# RPC endpoint for the target testnet or L2.
RPC_URL=

# Explorer API key used by forge verify-contract.
ETHERSCAN_API_KEY=

# Optional. Leave empty when using Foundry keystore, --account, or hardware wallets.
# Never commit real private keys. Use separate testnet keys.
PRIVATE_KEY=

# E-gold testnet deployment config.
# Do not reuse production attester keys on testnet.
EGOLD_MINTER=
EGOLD_ATTESTER_1=
EGOLD_ATTESTER_2=
EGOLD_ATTESTER_3=
EGOLD_THRESHOLD=2
EGOLD_ADDRESS=

# Local Anvil/testnet smoke keys only.
# Never use mainnet keys here.
# Never put production attester keys in .env.
EGOLD_MINTER_PRIVATE_KEY=
EGOLD_ATTESTER_1_PRIVATE_KEY=
EGOLD_ATTESTER_2_PRIVATE_KEY=
EGOLD_SMOKE_USER_PRIVATE_KEY=
